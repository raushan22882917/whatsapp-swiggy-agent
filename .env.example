# ── Twilio (WhatsApp) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Groq LLM ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Swiggy MCP — OAuth 2.1 + PKCE ────────────────────────────────────────────
# Run `node src/auth/swiggyOAuth.js` to get these tokens.
# Apply for credentials at https://mcp.swiggy.com/access (Builders Club)
SWIGGY_CLIENT_ID=your_swiggy_client_id
SWIGGY_REDIRECT_URI=http://localhost/callback
SWIGGY_ACCESS_TOKEN=your_swiggy_access_token
SWIGGY_REFRESH_TOKEN=your_swiggy_refresh_token

# Swiggy MCP server base URLs (defaults shown — only override for staging)
SWIGGY_FOOD_MCP_URL=https://mcp.swiggy.com/food
SWIGGY_IM_MCP_URL=https://mcp.swiggy.com/im
SWIGGY_DINEOUT_MCP_URL=https://mcp.swiggy.com/dineout

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
